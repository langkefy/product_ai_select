<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.select.product.mapper.KeywordConfigMapper">

    <select id="selectEnabled" resultType="com.select.product.entity.KeywordConfig">
        SELECT * FROM keyword_config WHERE enabled = 1 ORDER BY priority DESC
    </select>

</mapper>

